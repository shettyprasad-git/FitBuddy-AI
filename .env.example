# ── FitBuddy AI – Environment Variables (.env.example) ───────────────────────
# Copy this file to .env and fill in the real values.
# Never commit the .env file to source control.
# ─────────────────────────────────────────────────────────────────────────────

# Flask
SECRET_KEY=change-me-to-a-long-random-string
FLASK_ENV=development

# ── IBM watsonx Orchestrate ───────────────────────────────────────────────────
# The auto-generated service credential API key for your Orchestrate instance.
# Found in: IBM Cloud → Resource list → watsonx Orchestrate → Service credentials
ORCHESTRATE_API_KEY=your-orchestrate-service-credential-apikey

# The full instance URL from your service credentials JSON ("url" field).
ORCHESTRATE_URL=https://api.au-syd.watson-orchestrate.cloud.ibm.com/instances/your-instance-id

# The agent_id (URL slug) of the agent you created in the WXO UI.
# Steps to get this value:
#   1. Go to https://au-syd.watson-orchestrate.cloud.ibm.com
#   2. Create a new agent (e.g. name it "fitbuddy-ai")
#   3. Deploy / activate it
#   4. The agent's slug appears in the browser URL: /agents/<agent-slug>
# Leave blank to skip Orchestrate and use watsonx.ai directly.
ORCHESTRATE_AGENT_ID=your-agent-slug

# ── IBM Cloud Account ─────────────────────────────────────────────────────────
# Your IBM Cloud account-level API key.
# Used to call IBM watsonx.ai (fallback when no Orchestrate agent is deployed).
# Create at: IBM Cloud → Manage → Access (IAM) → API keys
IBM_CLOUD_API_KEY=your-ibm-cloud-account-api-key

# ── IBM watsonx.ai ────────────────────────────────────────────────────────────
# The project ID of your watsonx.ai project.
# Found in: watsonx.ai → Projects → your project → Manage → General → Project ID
WATSONX_PROJECT_ID=your-watsonx-project-id

# Regional watsonx.ai endpoint (defaults to au-syd; change for your region)
# us-south : https://us-south.ml.cloud.ibm.com
# eu-de    : https://eu-de.ml.cloud.ibm.com
# au-syd   : https://au-syd.ml.cloud.ibm.com
WATSONX_AI_URL=https://au-syd.ml.cloud.ibm.com

# Chat-capable model to use with watsonx.ai (confirmed available in au-syd)
WATSONX_CHAT_MODEL=meta-llama/llama-3-3-70b-instruct
